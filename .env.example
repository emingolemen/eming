# --- Database (Supabase or local Docker) ---
# Supabase: Project Settings → Database → Connection string (use pooler for Vercel when docs recommend).
# Local: docker compose up -d → use URL below.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/eming

# --- Payload ---
# Generate: openssl rand -base64 32
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Public site URL (no trailing slash). On Vercel, set to https://your-project.vercel.app or your domain.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

CRON_SECRET=YOUR_CRON_SECRET_HERE
PREVIEW_SECRET=YOUR_PREVIEW_SECRET_HERE

# --- Supabase Storage (S3-compatible uploads for production; optional locally → uses public/media) ---
# Dashboard → Storage → New bucket (e.g. media) → make it public for direct image URLs.
# Dashboard → Storage → Configuration → S3: endpoint, region, access keys.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_STORAGE_BUCKET=media
SUPABASE_STORAGE_REGION=
SUPABASE_STORAGE_ENDPOINT=https://YOUR_PROJECT.storage.supabase.co/storage/v1/s3
SUPABASE_STORAGE_ACCESS_KEY_ID=
SUPABASE_STORAGE_SECRET_ACCESS_KEY=
